<Entity>
	<InheritTransformComponent only_position="1" />

	<GameEffectComponent
		effect="CUSTOM"
		custom_effect_id="AP_JUMP_TRAP"
		frames="-1"
		/>

	<LuaComponent
		script_source_file="data/archipelago/scripts/status_effects/jumping.lua"
		execute_every_n_frame="1"
		/>

	<LuaComponent
		script_source_file="data/archipelago/scripts/status_effects/jumping_start.lua"
		execute_every_n_frame="1"
		remove_after_executed="1"
		/>

	<LuaComponent
		script_source_file="data/archipelago/scripts/status_effects/jumping_end.lua"
		execute_every_n_frame="-1"
		execute_on_removed="1"
		/>

	<VariableStorageComponent _tags="fly_time_max" name="fly_time_max" value_float="3" />

</Entity>
