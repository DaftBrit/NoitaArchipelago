<Entity name="$ap_animal_thwimp" >
	<SpriteComponent
		image_file="data/archipelago/entities/animals/thwimp.png"
		offset_x="5.5"
		offset_y="5.5"
		z_index="-1"
		update_transform_rotation="0"
		never_ragdollify_on_death="1"
		has_special_scale="1"
		special_scale_x="0.9"
		special_scale_y="0.9"
		/>

