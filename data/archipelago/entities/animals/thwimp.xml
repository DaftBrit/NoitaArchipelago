		execute_every_n_frame="1"
		vm_type="ONE_PER_COMPONENT_INSTANCE"
		/>

	<AreaDamageComponent
		update_every_n_frame="8"
		damage_per_frame="0.4"
		aabb_min.x="-8"
		aabb_min.y="-8"
		aabb_max.x="8"
		aabb_max.y="8"
