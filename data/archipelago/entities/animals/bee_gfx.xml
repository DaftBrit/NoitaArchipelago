<Sprite
  default_animation="fly_move"
  filename="data/projectiles_gfx/swarm_wasp.png"
	offset_x="4.5"
	offset_y="4.5" >

  <RectAnimation
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
    name="stand"
    pos_x="0"
    pos_y="0" />

  <RectAnimation
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
    name="walk"
    pos_x="0"
    pos_y="0" >

    <Event
      check_physics_material="1"
      frame="0"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

    <Event
      check_physics_material="1"
      frame="2"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

  </RectAnimation>

  <RectAnimation
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
    name="run"
    pos_x="0"
    pos_y="0" >

    <Event
      check_physics_material="1"
      frame="0"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

    <Event
      check_physics_material="1"
      frame="2"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

  </RectAnimation>

  <RectAnimation
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
    name="burn"
    pos_x="0"
    pos_y="0" >

    <Event
      check_physics_material="1"
      frame="0"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

    <Event
      check_physics_material="1"
      frame="2"
      max_distance="500"
      name="step"
      on_finished="0"
      probability="1" />

  </RectAnimation>

	<RectAnimation
		name="fly_move"
		pos_x="0"
		pos_y="0"
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
		loop="1"   />

		<RectAnimation
			name="fly_idle"
			pos_x="0"
			pos_y="0"
			frame_count="4"
			frame_width="9"
			frame_height="9"
			frame_wait="0.04"
			frames_per_row="4"
			loop="1"   />

  <RectAnimation
		frame_count="4"
		frame_width="9"
		frame_height="9"
		frame_wait="0.04"
		frames_per_row="4"
    name="attack_dash"
    pos_x="0"
    pos_y="0"
    shrink_by_one_pixel="1" >

    <Event
      check_physics_material="0"
      frame="0"
      max_distance="500"
      name="dash"
      on_finished="0"
      probability="1" />
  </RectAnimation>

</Sprite>
